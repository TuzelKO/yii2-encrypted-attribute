{
    "name": "tuzelko/yii2-encrypted-attribute",
    "description": "Transparent attribute encryption (sodium secretbox) for Yii2 ActiveRecord",
    "type": "yii2-extension",
    "keywords": ["yii2", "extension", "security", "encryption", "sodium", "activerecord", "behavior"],
    "license": "MIT",
    "authors": [
        {
            "name": "Eugene Frost"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.0",
        "yiisoft/yii2": "~2.0",
        "tuzelko/yii2-key-storage": "^1.0"
    },
    "suggest": {
        "ext-sodium": "Required by the default SodiumSecretboxCipher",
        "ext-openssl": "Required by AesGcmCipher"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "tuzelko\\yii\\encryptedattribute\\": "src/"
        }
    },
    "config": {
        "allow-plugins": {
            "yiisoft/yii2-composer": true
        }
    },
    "autoload-dev": {
        "psr-4": {
            "tuzelko\\yii\\encryptedattribute\\tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://asset-packagist.org"
        }
    ]
}